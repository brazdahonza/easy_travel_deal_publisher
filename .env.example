DATABASE_URL=postgresql://user:pass@db:5432/easy_travel_deal_publisher
INGEST_API_KEY=
# Bootstrap session blob (base64 JSON). Read once on first startup if the DB
# has no session yet; afterwards cookies are persisted in the database.
PATREON_SESSION=
# Used for in-process login when the stored session is missing or invalid.
PATREON_EMAIL=
PATREON_PASSWORD=
# Optional: base32 TOTP secret from authenticator-app 2FA. If set, codes are
# generated on every login — best for fully autonomous operation.
PATREON_TOTP_SECRET=
# Optional one-shot 2FA code (SMS/email OTP). Consumed once.
PATREON_2FA_CODE=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PATREON_HEADLESS=true
PATREON_SLOWMO_MS=0
PATREON_DRY_RUN=false
