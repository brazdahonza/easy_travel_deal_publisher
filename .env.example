# Required for write endpoints (POST /publish/patreon, POST /session/patreon)
INGEST_API_KEY=

# Patreon credentials — used by auto-login when no in-memory session is held
PATREON_EMAIL=
PATREON_PASSWORD=

# Optional: a base64-encoded session blob captured by `python -m app.session.setup_session`.
# When set, it seeds the in-memory session at startup. Otherwise the service auto-logs-in
# on the first /publish/patreon call.
PATREON_SESSION=

# Optional: Telegram alerts on session-renewal / unrecoverable failures
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Patreon publishing knobs
PATREON_HEADLESS=true
PATREON_DRY_RUN=false
PATREON_SLOWMO_MS=0
